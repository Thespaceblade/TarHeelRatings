{
    "manifest_version": 3,
    "name": "TarHeelRatings",
    "version": "1.0.0",
    "description": "Chrome extension that embeds RateMyProfessors data directly into UNC Chapel Hill's ConnectCarolina registration portal",
    "homepage_url": "https://github.com/jasoncharwin/TarHeelRatings",
    "permissions": ["storage"],
    "content_scripts": [
        {
            "matches": [
                "*://*.cc.unc.edu/*"
            ],
            "js": ["extension/reskin.js", "extension/content.js"],
            "css": ["extension/reskin.css", "extension/content.css"],
            "all_frames": true
        }
    ],
    "background" : {
        "service_worker": "extension/rmp.js"
    },
    "host_permissions": [
        "https://www.ratemyprofessors.com/*"
    ],
    "icons": {
        "16": "icons/store-icon-16.png",
        "48": "icons/store-icon-48.png",
        "128": "icons/store-icon-128.png"
    }
}